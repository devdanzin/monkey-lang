{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Monkey",
  "scopeName": "source.monkey",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": "//.*$", "name": "comment.line.double-slash.monkey" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block.monkey" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.monkey",
          "patterns": [
            { "match": "\\\\.", "name": "constant.character.escape.monkey" }
          ]
        },
        {
          "begin": "`",
          "end": "`",
          "name": "string.interpolated.monkey",
          "patterns": [
            { "begin": "\\$\\{", "end": "\\}", "name": "meta.template.expression.monkey",
              "patterns": [{ "include": "$self" }]
            },
            { "match": "\\\\.", "name": "constant.character.escape.monkey" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        { "match": "\\b(let|const|fn|return|if|else|while|for|in|do|break|continue|match|enum|import|from)\\b",
          "name": "keyword.control.monkey" },
        { "match": "\\b(true|false|null)\\b", "name": "constant.language.monkey" },
        { "match": "\\b(puts|len|push|first|last|rest|type|str|int)\\b",
          "name": "support.function.builtin.monkey" }
      ]
    },
    "operators": {
      "patterns": [
        { "match": "\\|>", "name": "keyword.operator.pipe.monkey" },
        { "match": "\\?\\.","name": "keyword.operator.optional-chain.monkey" },
        { "match": "\\?\\?", "name": "keyword.operator.null-coalescing.monkey" },
        { "match": "=>", "name": "keyword.operator.arrow.monkey" },
        { "match": "\\.\\.","name": "keyword.operator.range.monkey" },
        { "match": "[+\\-*/!<>=]=?|[&|^~]|<<|>>|%", "name": "keyword.operator.monkey" }
      ]
    },
    "numbers": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.monkey"
    },
    "functions": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": { "1": { "name": "entity.name.function.monkey" } }
    },
    "constants": {
      "match": "\\b[A-Z][A-Z0-9_]*\\b",
      "name": "variable.other.constant.monkey"
    }
  }
}
